{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kulpa.io/statements/0.1-preview/schema.json",
  "title": "Kulpa Statements",
  "description": "Schema for defining statement forms with various field types",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/field" }
    },
    "textTemplate": { "type": "string" }
  },
  "required": ["id", "name", "fields", "textTemplate"],
  "additionalProperties": false,
  "$defs": {
    "fieldUniqueIdentifier": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9-]+$",
      "minLength": 3,
      "maxLength": 64
    },
    "field": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "id": { "$ref": "#/$defs/fieldUniqueIdentifier" },
            "type": { "const": "number" },
            "label": { "type": "string" },
            "title": { "type": "string" },
            "properties": {
              "type": "object",
              "properties": {
                "defaultValue": { "type": "string" },
                "placeholder": { "type": "string" },
                "helpText": { "type": "string" },
                "required": { "type": "boolean", "default": false },
                "maximum": { "type": "number" },
                "minimum": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "required": ["id", "type", "properties"],
          "additionalProperties": false
        },
        {
          "properties": {
            "id": { "$ref": "#/$defs/fieldUniqueIdentifier" },
            "type": { "const": "string" },
            "label": { "type": "string" },
            "title": { "type": "string" },
            "properties": {
              "type": "object",
              "properties": {
                "defaultValue": { "type": "string" },
                "placeholder": { "type": "string" },
                "helpText": { "type": "string" },
                "required": { "type": "boolean", "default": false },
                "maxLength": { "type": "number", "maximum": 255 }
              },
              "additionalProperties": false
            }
          },
          "required": ["id", "type", "properties"],
          "additionalProperties": false
        },
        {
          "properties": {
            "id": { "$ref": "#/$defs/fieldUniqueIdentifier" },
            "type": { "const": "text" },
            "label": { "type": "string" },
            "title": { "type": "string" },
            "properties": {
              "type": "object",
              "properties": {
                "defaultValue": { "type": "string" },
                "placeholder": { "type": "string" },
                "helpText": { "type": "string" },
                "required": { "type": "boolean", "default": false },
                "text": { "type": "string" }
              },
              "required": ["text"],
              "additionalProperties": false
            }
          },
          "required": ["id", "type", "properties"],
          "additionalProperties": false
        },
        {
          "properties": {
            "id": { "$ref": "#/$defs/fieldUniqueIdentifier" },
            "type": { "const": "select" },
            "label": { "type": "string" },
            "title": { "type": "string" },
            "properties": {
              "type": "object",
              "properties": {
                "defaultValue": { "type": "string" },
                "placeholder": { "type": "string" },
                "helpText": { "type": "string" },
                "required": { "type": "boolean", "default": false },
                "options": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["value", "title"],
                    "properties": {
                      "value": { "type": "string" },
                      "title": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "required": ["options"],
              "additionalProperties": false
            }
          },
          "required": ["id", "type", "properties"],
          "additionalProperties": false
        },
        {
          "properties": {
            "id": { "$ref": "#/$defs/fieldUniqueIdentifier" },
            "type": { "const": "group" },
            "label": { "type": "string" },
            "title": { "type": "string" },
            "fields": {
              "type": "array",
              "items": { "$ref": "#/$defs/field" }
            },
            "properties": {
              "type": "object",
              "properties": {
                "defaultValue": { "type": "string" },
                "placeholder": { "type": "string" },
                "helpText": { "type": "string" },
                "required": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          },
          "required": ["id", "type", "properties", "fields"],
          "additionalProperties": false
        },
        {
          "properties": {
            "id": { "$ref": "#/$defs/fieldUniqueIdentifier" },
            "type": {
              "enum": [
                "longform",
                "emailAddress",
                "phoneNumber",
                "caseNumber",
                "date",
                "time",
                "dateTime",
                "boolean"
              ]
            },
            "label": { "type": "string" },
            "title": { "type": "string" },
            "properties": {
              "type": "object",
              "properties": {
                "defaultValue": { "type": "string" },
                "placeholder": { "type": "string" },
                "helpText": { "type": "string" },
                "required": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          },
          "required": ["id", "type", "properties"],
          "additionalProperties": false
        }
      ]
    }
  }
}
